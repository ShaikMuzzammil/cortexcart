# ─── DATABASE — SAME as main app ─────────────────────────────────────────
DATABASE_URL="postgresql://username:password@host/dbname?sslmode=require"

# ─── HOST AUTH ────────────────────────────────────────────────────────────
HOST_PASSWORD="your-strong-admin-password-here"
HOST_SECRET="run: openssl rand -base64 32   (min 32 chars)"

# ─── RESEND (same account as main) ───────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
# IMPORTANT: the domain in RESEND_FROM_EMAIL must be VERIFIED on your Resend
# account (resend.com/domains). Free/personal domains like gmail.com,
# outlook.com, yahoo.com, etc. can NEVER be verified — if used, the app will
# automatically fall back to onboarding@resend.dev so mail still sends.
RESEND_FROM_EMAIL="CortexCart Admin <admin@yourdomain.com>"

# Optional — customer replies to status/order emails will be routed here
CONTACT_EMAIL_TO="you@yourdomain.com"

# ─── MAIN APP URL (for email links) ──────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://cortexcart-main.vercel.app"
