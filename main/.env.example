# ─── DATABASE (Neon PostgreSQL) ──────────────────────────────────────────
DATABASE_URL="postgresql://username:password@host/dbname?sslmode=require"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://cortexcart-main.vercel.app"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# ─── GOOGLE OAUTH (optional) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── RESEND EMAIL ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="CortexCart <noreply@yourdomain.com>"
RESEND_FROM_ADMIN="CortexCart Admin <admin@yourdomain.com>"
CONTACT_EMAIL_TO="you@yourdomain.com"

# ─── APP URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://cortexcart-main.vercel.app"

# ─── HOST INTEGRATION ─────────────────────────────────────────────────────
HOST_API_KEY="generate-a-secure-random-key"
