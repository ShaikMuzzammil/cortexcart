# ════════════════════════════════════════════════════════════════
#  NEON POSTGRESQL — Two URLs, both from your Neon dashboard
# ════════════════════════════════════════════════════════════════
#
#  Go to: neon.tech → Your Project → Connection Details
#
#  DATABASE_URL  → Toggle "Pooled connection" ON  → copy URL
#  DIRECT_URL    → Toggle "Pooled connection" OFF → copy URL
#
#  The only difference is "-pooler" in the hostname:
#
#  DATABASE_URL = ...ep-flat-brook-a1b2c3-pooler.us-east-1...  (HAS -pooler)
#  DIRECT_URL   = ...ep-flat-brook-a1b2c3.us-east-1...         (NO  -pooler)
#
DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# ════════════════════════════════════════════════════════════════
#  NEXTAUTH
# ════════════════════════════════════════════════════════════════
NEXTAUTH_URL="https://your-main-app.vercel.app"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# ════════════════════════════════════════════════════════════════
#  RESEND EMAIL  — resend.com (free: 3000 emails/month)
# ════════════════════════════════════════════════════════════════
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="CortexCart <noreply@yourdomain.com>"
CONTACT_EMAIL_TO="you@yourdomain.com"

# ════════════════════════════════════════════════════════════════
#  APP
# ════════════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_URL="https://your-main-app.vercel.app"
HOST_API_KEY="any-random-secure-string"
# ─── AI (Gemini is FREE forever — Groq optional for extra headroom) ──
# Gemini (FREE, no card): https://aistudio.google.com/apikey
#   gemini-2.5-flash-lite free tier ≈ 15 RPM / ~1,000 requests per day
#   (Google's free-tier limits change periodically — if you start seeing
#   429 TooManyRequests in the AI Studio usage dashboard, the app already
#   self-throttles and falls back automatically, no action needed. Adding
#   GROQ_API_KEY below gives a much higher-ceiling free fallback.)
GEMINI_API_KEY=AIza...

# Groq (FREE, no card, optional extra fallback): https://console.groq.com/keys
#   llama-3.1-8b-instant free tier ≈ 30 RPM / 14,400 requests per day —
#   used automatically as a second provider if Gemini is rate-limited.
# GROQ_API_KEY=gsk_...

# Anthropic (optional override, paid): https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
