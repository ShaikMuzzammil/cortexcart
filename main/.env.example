# ─── DATABASE (Neon PostgreSQL) ────────────────────────────────────────────
#
# DATABASE_URL  → Pooler URL  (for app queries at runtime — includes "-pooler")
# DIRECT_URL    → Direct URL  (for prisma db push during build — no "-pooler")
#
# Both are on your Neon dashboard under "Connection Details"
# Toggle "Pooled connection" ON  → copy → this is DATABASE_URL
# Toggle "Pooled connection" OFF → copy → this is DIRECT_URL
#
# Example:
# DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxxx.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require"
#
DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── NEXTAUTH ──────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://your-main-app.vercel.app"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# ─── RESEND EMAIL ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="CortexCart <noreply@yourdomain.com>"
CONTACT_EMAIL_TO="you@yourdomain.com"

# ─── APP ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-main-app.vercel.app"
HOST_API_KEY="any-random-secure-string"
