{
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma db push --skip-generate --accept-data-loss && npm run db:seed && next build",
  "installCommand": "npm install --ignore-scripts",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "env": {
    "PRISMA_GENERATE_SKIP_AUTOINSTALL": "true"
  },
  "functions": {
    "src/app/api/**/*.ts": { "maxDuration": 30 }
  }
}
