# ────────────────────────────────────────────────────────────────
#  CortexCart Monorepo — root .gitignore
#  Covers: main/ (Next.js store) + host/ (Next.js admin dashboard)
# ────────────────────────────────────────────────────────────────

# ── Node / package managers ──────────────────────────────────────
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Next.js build output ─────────────────────────────────────────
.next/
**/.next/
out/
**/out/
build/
dist/

# ── Environment files — NEVER commit secrets ─────────────────────
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.staging
.env.staging.local
.env.test
.env.test.local
.env*.local
**/.env
**/.env.local
**/.env*.local
# ✅ .env.example IS committed (safe template, no real values)

# ── Prisma ───────────────────────────────────────────────────────
# Generated client (recreated by `prisma generate` on each deploy)
**/prisma/generated/
# Migration history (using db push not migrate)
# **/prisma/migrations/   ← uncomment if you switch to prisma migrate

# ── Vercel ───────────────────────────────────────────────────────
.vercel
**/.vercel

# ── OS / IDE / editor ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.directory

# JetBrains (WebStorm / IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.#*

# ── Logs & debug ─────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Testing ──────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
junit.xml
test-results/

# ── TypeScript ───────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Misc ─────────────────────────────────────────────────────────
*.pem
.cache/
.parcel-cache/
.turbo/
storybook-static/
