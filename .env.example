# ── Database ──────────────────────────────────────────────────────────────
# Get from https://neon.tech (free)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/cortexcart?sslmode=require"

# ── Resend Email ──────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY="re_YOUR_API_KEY"

# ── Your Gmail (all emails — orders, contacts — are forwarded here) ───────
CONTACT_EMAIL_TO="your-gmail@gmail.com"
RESEND_FROM_EMAIL="CortexCart <onboarding@resend.dev>"

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-random-32-char-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Stripe (optional - use placeholders for now) ─────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"
STRIPE_SECRET_KEY="sk_test_placeholder"
