# ─── Database (Neon / Supabase / Railway) ────────────────────────────────────
DATABASE_URL="postgresql://username:password@host:5432/cortexcart?sslmode=require"
# DIRECT_URL is optional - needed for Prisma on serverless (Neon pooled connections)
# If using Neon: use pooled URL for DATABASE_URL, direct URL for DIRECT_URL
# If not using Neon: set DIRECT_URL same as DATABASE_URL
DIRECT_URL="postgresql://username:password@host:5432/cortexcart?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate: openssl rand -base64 32"

# ─── Resend Email ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_key_here"
RESEND_FROM_EMAIL="CortexCart <onboarding@resend.dev>"
CONTACT_EMAIL_TO="admin@your-domain.com"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
