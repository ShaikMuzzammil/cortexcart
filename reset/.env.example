# ── Database ─────────────────────────────────────────────────────────────────
# SAME Neon connection string as main/ — this app reads from the same DB.
# NEVER run prisma db push or prisma migrate from this app.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Main store URL ────────────────────────────────────────────────────────────
# Used for "Back to CortexCart" links, "Sign In" buttons, and confirmation emails.
NEXT_PUBLIC_APP_URL="https://your-main-app.vercel.app"

# ── Email ─────────────────────────────────────────────────────────────────────
# Same Resend account as main/ and host/.
RESEND_API_KEY="re_xxxxxxxxxxxx"
# MUST be on a domain verified at resend.com/domains.
# Unverifiable domains (gmail.com, outlook.com, etc.) auto-fall back to onboarding@resend.dev.
RESEND_FROM_EMAIL="CortexCart <noreply@yourdomain.com>"
